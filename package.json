{
  "name": "receipts",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run typecheck && npm run test",
    "build": "npm run build -w @witnessed/core && npm run build -w @witnessed/verifier && npm run build -w @witnessed/sdk && npm run build -w @witnessed/mcp",
    "gen:witness-key": "tsx packages/witness/src/gen-key.ts",
    "start:witness": "tsx packages/witness/src/server.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "tsx": "^4.19.0",
    "tsup": "^8.3.0"
  }
}
