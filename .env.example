# Witness service configuration (copy to .env; never commit real secrets).

PORT=8787

# REQUIRED. Generate with: npm run gen:witness-key
# Paste the printed WITNESS_PRIVATE_JWK value here and store it as a host SECRET.
WITNESS_PRIVATE_JWK=

# Durable storage. Omit for in-memory (non-durable, dev only).
RECEIPTS_DB=./data/receipts.db
# Retention window in days (EU AI Act high-risk logs: >= ~180). Omit to retain indefinitely.
RETENTION_DAYS=180

# x402 billing — set ALL FIVE to charge per receipt (USDC amounts are atomic units; 10000 = $0.01).
# X402_FACILITATOR_URL=https://x402.org/facilitator
# X402_NETWORK=base
# X402_ASSET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# X402_PAY_TO=0xYourTreasuryAddress
# X402_AMOUNT=10000

# Rate limiting (per-IP safety ceiling; on by default). Window is a fixed 60s.
# RL_ENABLED=true
# RL_WRITE_PER_MIN=30           # per-IP: POST /receipts, /verify, /mcp
# RL_READ_PER_MIN=120           # per-IP: reads (manifest, /public-key, GET /receipts/:id)
# RL_GLOBAL_WRITE_PER_MIN=300   # process-wide write ceiling across all IPs (0 disables)
